{
  "name": "multi-react",
  "version": "0.1.0",
  "description": "Shared React components for Multi ecosystem",
  "license": "AGPL-3.0-only",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "npm run build && node --test test/*.test.cjs"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "diff2html": "^3.4.48",
    "lucide-react": "^0.468.0",
    "tailwind-merge": "^2.6.0"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsup": "^8.3.0",
    "typescript": "^5.8.0"
  }
}
